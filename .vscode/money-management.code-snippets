	"Dart Async Cubit Logic": {
		"prefix": "fcubit",
		"body": [
			"import 'package:flutter_bloc/flutter_bloc.dart';",
			"import 'package:injectable/injectable.dart';",
			"import 'package:logging/logging.dart';",
			"import 'package:money_management_mobile/core/error/execeptions.dart';",
			"",
			"@Injectable()",
			"class ${1:Name}Cubit extends Cubit<${1:Name}State> {",
			"  final _log = Logger('${1:Name}Cubit');",
			"  // final UseCase useCase;",
			"",
			"  ${1:Name}Cubit() : super(${1:Name}Initial());",
			"",
			"  Future<void> execute() async {",
			"    emit(${1:Name}Loading());",
			"    try {",
			"      // final result = await useCase.call();",
			"      emit(${1:Name}Success(null));",
			"    } on ServerException catch (e) {",
			"      emit(${1:Name}Error(e.message));",
			"    } catch (e) {",
			"      _log.severe('Error in ${1:Name}Cubit', e);",
			"      emit(${1:Name}Error('Terjadi kesalahan tidak terduga'));",
			"    }",
			"  }",
			"}",
		],
		"description": "Cubit Class dengan Injectable dan Error Handling",
	},
	"Dart Clean Repository": {
		"prefix": "fclean-repo",
		"body": [
			"// Domain Layer: Interface",
			"// Pindahkan ke repository domain layer",
			"abstract class ${1:Name}Repository {",
			"  Future<void> ${2:method}();",
			"}",
			"",
			"// Data Layer: Implementation",
			"// Pindahkan ke repository data layer",
			"@Injectable(as: ${1:Name}Repository)",
			"class ${1:Name}RepositoryImpl implements ${1:Name}Repository {",
			"  final ${1:Name}RemoteDataSource remoteDataSource;",
			"",
			"  ${1:Name}RepositoryImpl(this.remoteDataSource);",
			"",
			"  @override",
			"  Future<void> ${2:method}() async {",
			"    return await remoteDataSource.${2:method}();",
			"  }",
			"}",
		],
		"description": "Repository Interface dan Implementation",
	},
