			"class ${1:Name}RemoteDataSource {",
			"  final Dio dio;",
			"  final _log = Logger('${1:Name}RemoteDataSource');",
			"",
			"  ${1:Name}RemoteDataSource(this.dio);",
			"",
			"  Future<void> ${2:methodName}() async {",
			"    try {",
			"      final response = await dio.get('/${3:path}');",
			"      ${0}",
			"    } on DioException catch (e) {",
			"      throw ErrorHandler.handleRemoteException(e, _log, '${1:Name}');",
			"    } catch (e) {",
			"      _log.severe('Unexpected error', e);",
			"      throw UnexpectedException('Terjadi kesalahan sistem');",
			"    }",
			"  }",
			"}",
		],
		"description": "Remote Data Source dengan Injectable",
	},
